# Database
DATABASE_URL=postgresql+psycopg2://ols_user:ols_password@postgres:5432/ols_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Cloudinary (leave blank in dev to fall back to local disk storage under /app/media)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Uploads
MAX_UPLOAD_MB=20
